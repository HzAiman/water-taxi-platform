rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOperator() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/operators/$(request.auth.uid));
    }

    function bookingOperatorId(data) {
      return data.keys().hasAny(['operatorId'])
        ? data.operatorId
        : data.driverId;
    }

    function isAssignedOperator() {
      return isOperator() && bookingOperatorId(resource.data) == request.auth.uid;
    }

    function bookingCreateHasExpectedFields() {
      return request.resource.data.keys().hasOnly([
        'bookingId',
        'userId',
        'userName',
        'userPhone',
        'origin',
        'destination',
        'routeKey',
        'originCoords',
        'destinationCoords',
        'adultCount',
        'childCount',
        'passengerCount',
        'adultFare',
        'childFare',
        'adultSubtotal',
        'childSubtotal',
        'fare',
        'totalFare',
        'paymentMethod',
        'paymentStatus',
        'orderNumber',
        'transactionId',
        'status',
        'operatorId',
        'driverId',
        'createdAt',
        'updatedAt'
      ]);
    }

    function bookingUpdateHasExpectedFields() {
      return request.resource.data.keys().hasOnly([
        'bookingId',
        'userId',
        'userName',
        'userPhone',
        'origin',
        'destination',
        'routeKey',
        'originCoords',
        'destinationCoords',
        'adultCount',
        'childCount',
        'passengerCount',
        'adultFare',
        'childFare',
        'adultSubtotal',
        'childSubtotal',
        'fare',
        'totalFare',
        'paymentMethod',
        'paymentStatus',
        'orderNumber',
        'transactionId',
        'status',
        'operatorId',
        'driverId',
        'rejectedBy',
        'createdAt',
        'updatedAt',
        'cancelledAt'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId);
    }

    match /operators/{operatorUid} {
      allow read: if isOwner(operatorUid);
      allow create: if isOwner(operatorUid)
        && request.resource.data.keys().hasAll(['name', 'operatorId', 'email']);
      allow update: if isOwner(operatorUid);
      allow delete: if false;
    }

    match /operator_presence/{operatorUid} {
      allow read: if isSignedIn();
      allow create: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['isOnline', 'updatedAt']);
      allow update: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['isOnline', 'updatedAt']);
      allow delete: if false;
    }

    match /user_devices/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['token', 'platform', 'appRole', 'updatedAt'])
        && request.resource.data.appRole == 'passenger';
      allow delete: if isOwner(userId);
    }

    match /operator_devices/{operatorUid} {
      allow read: if isOwner(operatorUid);
      allow create, update: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['token', 'platform', 'appRole', 'updatedAt'])
        && request.resource.data.appRole == 'operator';
      allow delete: if isOwner(operatorUid);
    }

    match /jetties/{jettyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /fares/{fareId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isOwner(resource.data.userId) || isOperator();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.bookingId == bookingId
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'authorized'
        && bookingCreateHasExpectedFields();

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookingId == resource.data.bookingId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt'])
        && ['pending', 'accepted', 'on_the_way'].hasAny([resource.data.status])
        && request.resource.data.status == 'cancelled'
        && bookingUpdateHasExpectedFields();

      allow update: if isOperator()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookingId == resource.data.bookingId
        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorId', 'driverId'])
            &&
            resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && bookingOperatorId(request.resource.data) == request.auth.uid
            && bookingOperatorId(resource.data) == null
            && !(
              resource.data.keys().hasAny(['rejectedBy'])
              && resource.data.rejectedBy.hasAny([request.auth.uid])
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorId', 'driverId'])
            &&
            resource.data.status == 'accepted'
            && request.resource.data.status == 'on_the_way'
            && bookingOperatorId(request.resource.data) == bookingOperatorId(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorId', 'driverId', 'rejectedBy'])
            && resource.data.status == 'accepted'
            && request.resource.data.status == 'pending'
            && isAssignedOperator()
            && bookingOperatorId(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorId', 'driverId'])
            &&
            resource.data.status == 'on_the_way'
            && request.resource.data.status == 'completed'
            && bookingOperatorId(request.resource.data) == bookingOperatorId(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['rejectedBy', 'updatedAt'])
            && resource.data.status == 'pending'
            && request.resource.data.status == resource.data.status
            && bookingOperatorId(request.resource.data) == bookingOperatorId(resource.data)
            && bookingOperatorId(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'rejectedBy', 'updatedAt'])
            && resource.data.status == 'pending'
            && request.resource.data.status == 'rejected'
            && bookingOperatorId(request.resource.data) == bookingOperatorId(resource.data)
            && bookingOperatorId(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
        )
        && bookingUpdateHasExpectedFields();

      allow delete: if false;
    }
  }
}