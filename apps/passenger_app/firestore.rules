rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOperator() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/operators/$(request.auth.uid));
    }

    function bookingOperatorUid(data) {
      return data.keys().hasAny(['operatorUid'])
        ? data.operatorUid
        : data.operatorId;
    }

    function validOperatorProfile(data) {
      return data.keys().hasAll(['name', 'operatorId', 'email'])
        && data.operatorId is string
        && data.operatorId.size() > 0;
    }

    function operatorProfileAllowedKeys(data) {
      return data.keys().hasOnly([
        'name',
        'operatorId',
        'email',
        'createdAt',
        'updatedAt',
        // Legacy compatibility keys that may still exist on older docs.
        'operatorIdKey',
        'isOnline'
      ]);
    }

    function isAssignedOperator() {
      return isOperator() && bookingOperatorUid(resource.data) == request.auth.uid;
    }

    function bookingCreateHasExpectedFields() {
      return request.resource.data.keys().hasOnly([
        'bookingId',
        'userId',
        'userName',
        'userPhone',
        'origin',
        'destination',
        'originJettyId',
        'destinationJettyId',
        'routeKey',
        'routePolylineId',
        'originCoords',
        'destinationCoords',
        'routePolyline',
        'routeCoordinates',
        'polylineCoordinates',
        'routePoints',
        'adultCount',
        'childCount',
        'passengerCount',
        'adultFare',
        'childFare',
        'adultSubtotal',
        'childSubtotal',
        'fare',
        'totalFare',
        'fareSnapshotId',
        'paymentMethod',
        'paymentStatus',
        'orderNumber',
        'transactionId',
        'status',
        'operatorUid',
        'operatorId',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasAll([
        'originJettyId',
        'destinationJettyId',
        'fareSnapshotId'
      ])
      && request.resource.data.originJettyId is string
      && request.resource.data.destinationJettyId is string
      && request.resource.data.fareSnapshotId is string;
    }

    function bookingUpdateHasExpectedFields() {
      return request.resource.data.keys().hasOnly([
        'bookingId',
        'userId',
        'userName',
        'userPhone',
        'origin',
        'destination',
        'originJettyId',
        'destinationJettyId',
        'routeKey',
        'routePolylineId',
        'originCoords',
        'destinationCoords',
        'routePolyline',
        'routeCoordinates',
        'polylineCoordinates',
        'routePoints',
        'adultCount',
        'childCount',
        'passengerCount',
        'adultFare',
        'childFare',
        'adultSubtotal',
        'childSubtotal',
        'fare',
        'totalFare',
        'fareSnapshotId',
        'paymentMethod',
        'paymentStatus',
        'orderNumber',
        'transactionId',
        'status',
        'operatorUid',
        'operatorId',
        'operatorLat',
        'operatorLng',
        'rejectedBy',
        'createdAt',
        'updatedAt',
        'cancelledAt'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'phoneNumber',
          'createdAt',
          'updatedAt'
        ])
        && (
          !request.resource.data.keys().hasAny(['uid'])
          || request.resource.data.uid == request.auth.uid
        );
      allow update: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'phoneNumber',
          'createdAt',
          'updatedAt'
        ])
        && (
          !request.resource.data.keys().hasAny(['uid'])
          || request.resource.data.uid == request.auth.uid
        );
      allow delete: if isOwner(userId);
    }

    match /operators/{operatorUid} {
      allow read: if isOwner(operatorUid);
      allow create: if isOwner(operatorUid)
        && validOperatorProfile(request.resource.data)
        && operatorProfileAllowedKeys(request.resource.data);
      allow update: if isOwner(operatorUid)
        && validOperatorProfile(request.resource.data)
        && operatorProfileAllowedKeys(request.resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'operatorId',
          'email',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /operator_presence/{operatorUid} {
      allow read: if isSignedIn();
      allow create: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['isOnline', 'updatedAt']);
      allow update: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['isOnline', 'updatedAt']);
      allow delete: if false;
    }

    match /user_devices/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['token', 'platform', 'appRole', 'updatedAt'])
        && request.resource.data.appRole == 'passenger';
      allow delete: if isOwner(userId);
    }

    match /operator_devices/{operatorUid} {
      allow read: if isOwner(operatorUid);
      allow create, update: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['token', 'platform', 'appRole', 'updatedAt'])
        && request.resource.data.appRole == 'operator';
      allow delete: if isOwner(operatorUid);
    }

    match /order_number_index/{orderNumber} {
      // Booking flow reserves order numbers with a transaction that first
      // performs tx.get(orderNumber). Allow signed-in reads for that
      // existence check, then keep create strictly owner-bound.
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['orderNumber', 'userId', 'reservedAt', 'expiresAt'])
        && request.resource.data.orderNumber == orderNumber
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /tracking/{bookingId} {
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/bookings/$(bookingId))
        && (
          isOwner(get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId)
          || (
            isOperator()
            && bookingOperatorUid(get(/databases/$(database)/documents/bookings/$(bookingId)).data) == request.auth.uid
          )
        );
      allow create, update: if isOperator()
        && exists(/databases/$(database)/documents/bookings/$(bookingId))
        && request.resource.data.keys().hasOnly([
          'bookingId',
          'operatorUid',
          'operatorLat',
          'operatorLng',
          'updatedAt'
        ])
        && request.resource.data.bookingId == bookingId
        && request.resource.data.operatorUid == request.auth.uid
        && bookingOperatorUid(get(/databases/$(database)/documents/bookings/$(bookingId)).data) == request.auth.uid;
      allow delete: if false;
    }

    match /jetties/{jettyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /fares/{fareId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /polylines/{polylineId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isOwner(resource.data.userId)
        || (
          isOperator()
          && (
            resource.data.status == 'pending'
            || bookingOperatorUid(resource.data) == request.auth.uid
          )
        );

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.bookingId == bookingId
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'authorized'
        && bookingCreateHasExpectedFields();

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookingId == resource.data.bookingId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt'])
        && ['pending', 'accepted', 'on_the_way'].hasAny([resource.data.status])
        && request.resource.data.status == 'cancelled'
        && bookingUpdateHasExpectedFields();

      allow update: if isOperator()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookingId == resource.data.bookingId
        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'status',
              'updatedAt',
              'operatorUid',
              'operatorId'
            ])
            &&
            resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && bookingOperatorUid(request.resource.data) == request.auth.uid
            && bookingOperatorUid(resource.data) == null
            && !(
              resource.data.keys().hasAny(['rejectedBy'])
              && resource.data.rejectedBy.hasAny([request.auth.uid])
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorUid', 'operatorId', 'operatorLat', 'operatorLng'])
            &&
            resource.data.status == 'accepted'
            && request.resource.data.status == 'on_the_way'
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorUid', 'operatorId', 'rejectedBy'])
            && resource.data.status == 'accepted'
            && request.resource.data.status == 'pending'
            && isAssignedOperator()
            && bookingOperatorUid(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorUid', 'operatorId'])
            &&
            resource.data.status == 'on_the_way'
            && request.resource.data.status == 'completed'
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['updatedAt', 'operatorLat', 'operatorLng'])
            && resource.data.status == 'on_the_way'
            && request.resource.data.status == resource.data.status
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['rejectedBy', 'updatedAt'])
            && resource.data.status == 'pending'
            && request.resource.data.status == resource.data.status
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && bookingOperatorUid(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'rejectedBy', 'updatedAt'])
            && resource.data.status == 'pending'
            && request.resource.data.status == 'rejected'
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && bookingOperatorUid(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
        )
        && bookingUpdateHasExpectedFields();

      allow delete: if false;

      match /statusHistory/{statusHistoryId} {
        allow read: if isOwner(get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId)
          || (
            isOperator()
            && bookingOperatorUid(get(/databases/$(database)/documents/bookings/$(bookingId)).data) == request.auth.uid
          );
        allow create: if isSignedIn()
          && request.resource.data.keys().hasOnly([
            'from',
            'to',
            'changedBy',
            'source',
            'timestamp'
          ])
          && request.resource.data.changedBy == request.auth.uid
          && request.resource.data.source in ['passenger_app', 'operator_app']
          && (
            isOwner(get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId)
            || isOperator()
          );
        allow update, delete: if false;
      }
    }

    match /bookings_archive/{bookingId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll([
          'bookingId',
          'userId',
          'status',
          'archivedAt',
          'archivedStatus'
        ])
        && request.resource.data.bookingId == bookingId
        && (
          isOwner(request.resource.data.userId)
          || (
            isOperator()
            && bookingOperatorUid(request.resource.data) == request.auth.uid
          )
        );
      allow read: if isOwner(resource.data.userId)
        || (
          isOperator()
          && bookingOperatorUid(resource.data) == request.auth.uid
        );
      allow update, delete: if false;
    }
  }
}