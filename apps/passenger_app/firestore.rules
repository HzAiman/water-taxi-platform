rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOperator() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/operators/$(request.auth.uid));
    }

    function bookingOperatorUid(data) {
      return data.keys().hasAny(['operatorUid'])
        ? data.operatorUid
        : data.operatorId;
    }

    function operatorClaimPath(operatorIdKey) {
      return /databases/$(database)/documents/operator_id_claims/$(operatorIdKey);
    }

    function validOperatorProfile(data) {
      return data.keys().hasAll(['name', 'operatorId', 'operatorIdKey', 'email'])
        && data.operatorId is string
        && data.operatorIdKey is string
        && data.operatorIdKey == data.operatorId
        && data.operatorIdKey.size() > 0;
    }

    function operatorClaimOwnedAfter(operatorIdKey) {
      return existsAfter(operatorClaimPath(operatorIdKey))
        && getAfter(operatorClaimPath(operatorIdKey)).data.uid == request.auth.uid;
    }

    function isAssignedOperator() {
      return isOperator() && bookingOperatorUid(resource.data) == request.auth.uid;
    }

    function bookingCreateHasExpectedFields() {
      return request.resource.data.keys().hasOnly([
        'bookingId',
        'userId',
        'userName',
        'userPhone',
        'origin',
        'destination',
        'routeKey',
        'corridorId',
        'corridorVersion',
        'originCheckpointSeq',
        'destinationCheckpointSeq',
        'originCoords',
        'destinationCoords',
        'routePolyline',
        'routeCoordinates',
        'polylineCoordinates',
        'routePoints',
        'adultCount',
        'childCount',
        'passengerCount',
        'adultFare',
        'childFare',
        'adultSubtotal',
        'childSubtotal',
        'fare',
        'totalFare',
        'paymentMethod',
        'paymentStatus',
        'orderNumber',
        'transactionId',
        'status',
        'operatorUid',
        'operatorId',
        'createdAt',
        'updatedAt'
      ]);
    }

    function bookingUpdateHasExpectedFields() {
      return request.resource.data.keys().hasOnly([
        'bookingId',
        'userId',
        'userName',
        'userPhone',
        'origin',
        'destination',
        'routeKey',
        'corridorId',
        'corridorVersion',
        'originCheckpointSeq',
        'destinationCheckpointSeq',
        'originCoords',
        'destinationCoords',
        'routePolyline',
        'routeCoordinates',
        'polylineCoordinates',
        'routePoints',
        'adultCount',
        'childCount',
        'passengerCount',
        'adultFare',
        'childFare',
        'adultSubtotal',
        'childSubtotal',
        'fare',
        'totalFare',
        'paymentMethod',
        'paymentStatus',
        'orderNumber',
        'transactionId',
        'status',
        'operatorUid',
        'operatorId',
        'operatorLat',
        'operatorLng',
        'rejectedBy',
        'createdAt',
        'updatedAt',
        'cancelledAt'
      ]);
    }

    function canonicalCorridorId() {
      return 'melaka_main_01';
    }

    function canonicalCheckpointOrder() {
      return [
        'JETTY_01',
        'JETTY_02',
        'JETTY_03',
        'JETTY_04',
        'JETTY_05',
        'JETTY_06',
        'JETTY_07',
        'JETTY_08',
        'JETTY_09',
        'JETTY_10',
        'JETTY_11',
        'JETTY_12',
        'JETTY_13',
        'JETTY_14'
      ];
    }

    function hasCorridorBookingMetadata(data) {
      return data.keys().hasAny([
        'corridorId',
        'corridorVersion',
        'originCheckpointSeq',
        'destinationCheckpointSeq'
      ]);
    }

    function validCorridorBookingMetadata(data) {
      return !hasCorridorBookingMetadata(data)
        || (
          data.keys().hasAll([
            'corridorId',
            'corridorVersion',
            'originCheckpointSeq',
            'destinationCheckpointSeq'
          ])
          && data.corridorId == canonicalCorridorId()
          && data.corridorVersion is int
          && data.corridorVersion >= 1
          && data.originCheckpointSeq is int
          && data.destinationCheckpointSeq is int
          && data.originCheckpointSeq >= 1
          && data.destinationCheckpointSeq <= 14
          && data.originCheckpointSeq < data.destinationCheckpointSeq
        );
    }

    function validCanonicalCorridor(data, corridorId) {
      return corridorId == canonicalCorridorId()
        && data.keys().hasAll([
          'corridorId',
          'corridorName',
          'riverName',
          'isActive',
          'version',
          'checkpointCount',
          'checkpointOrder',
          'checkpoints',
          'polyline',
          'updatedAt'
        ])
        && data.corridorId == corridorId
        && data.corridorName is string
        && data.riverName is string
        && data.isActive is bool
        && data.version is int
        && data.version >= 1
        && data.checkpointCount is int
        && data.checkpointCount == 14
        && data.checkpointOrder is list
        && data.checkpointOrder == canonicalCheckpointOrder()
        && data.checkpoints is list
        && data.checkpoints.size() == 14
        && data.polyline is list;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId);
    }

    match /operators/{operatorUid} {
      allow read: if isOwner(operatorUid);
      allow create: if isOwner(operatorUid)
        && validOperatorProfile(request.resource.data)
        && operatorClaimOwnedAfter(request.resource.data.operatorIdKey);
      allow update: if isOwner(operatorUid)
        && validOperatorProfile(request.resource.data)
        && operatorClaimOwnedAfter(request.resource.data.operatorIdKey);
      allow delete: if false;
    }

    match /operator_id_claims/{operatorIdKey} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && !exists(/databases/$(database)/documents/operator_id_claims/$(operatorIdKey))
        && request.resource.data.keys().hasOnly(['uid', 'operatorId', 'operatorIdKey', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.operatorId is string
        && request.resource.data.operatorIdKey is string
        && request.resource.data.operatorIdKey == operatorIdKey
        && request.resource.data.operatorIdKey == request.resource.data.operatorId;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'operatorId', 'operatorIdKey', 'createdAt', 'updatedAt'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.operatorIdKey == resource.data.operatorIdKey
        && request.resource.data.operatorIdKey == operatorIdKey
        && request.resource.data.operatorId is string
        && request.resource.data.operatorIdKey == request.resource.data.operatorId;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /operator_presence/{operatorUid} {
      allow read: if isSignedIn();
      allow create: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['isOnline', 'updatedAt']);
      allow update: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['isOnline', 'updatedAt']);
      allow delete: if false;
    }

    match /user_devices/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['token', 'platform', 'appRole', 'updatedAt'])
        && request.resource.data.appRole == 'passenger';
      allow delete: if isOwner(userId);
    }

    match /operator_devices/{operatorUid} {
      allow read: if isOwner(operatorUid);
      allow create, update: if isOwner(operatorUid)
        && request.resource.data.keys().hasOnly(['token', 'platform', 'appRole', 'updatedAt'])
        && request.resource.data.appRole == 'operator';
      allow delete: if isOwner(operatorUid);
    }

    match /jetties/{jettyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /fares/{fareId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /navigation_corridors/{corridorId} {
      allow read: if isSignedIn() && validCanonicalCorridor(resource.data, corridorId);
      allow create, update, delete: if false;
    }

    match /polylines/{polylineId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if isOwner(resource.data.userId)
        || (
          isOperator()
          && (
            resource.data.status == 'pending'
            || bookingOperatorUid(resource.data) == request.auth.uid
          )
        );

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.bookingId == bookingId
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'authorized'
        && bookingCreateHasExpectedFields()
        && validCorridorBookingMetadata(request.resource.data);

      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookingId == resource.data.bookingId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'cancelledAt'])
        && ['pending', 'accepted', 'on_the_way'].hasAny([resource.data.status])
        && request.resource.data.status == 'cancelled'
        && bookingUpdateHasExpectedFields()
        && validCorridorBookingMetadata(request.resource.data);

      allow update: if isOperator()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.bookingId == resource.data.bookingId
        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'status',
              'updatedAt',
              'operatorUid',
              'operatorId',
              'corridorId',
              'corridorVersion',
              'originCheckpointSeq',
              'destinationCheckpointSeq'
            ])
            &&
            resource.data.status == 'pending'
            && request.resource.data.status == 'accepted'
            && bookingOperatorUid(request.resource.data) == request.auth.uid
            && bookingOperatorUid(resource.data) == null
            && !(
              resource.data.keys().hasAny(['rejectedBy'])
              && resource.data.rejectedBy.hasAny([request.auth.uid])
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorUid', 'operatorId', 'operatorLat', 'operatorLng'])
            &&
            resource.data.status == 'accepted'
            && request.resource.data.status == 'on_the_way'
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorUid', 'operatorId', 'rejectedBy'])
            && resource.data.status == 'accepted'
            && request.resource.data.status == 'pending'
            && isAssignedOperator()
            && bookingOperatorUid(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt', 'operatorUid', 'operatorId'])
            &&
            resource.data.status == 'on_the_way'
            && request.resource.data.status == 'completed'
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['updatedAt', 'operatorLat', 'operatorLng'])
            && resource.data.status == 'on_the_way'
            && request.resource.data.status == resource.data.status
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && isAssignedOperator()
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['rejectedBy', 'updatedAt'])
            && resource.data.status == 'pending'
            && request.resource.data.status == resource.data.status
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && bookingOperatorUid(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'rejectedBy', 'updatedAt'])
            && resource.data.status == 'pending'
            && request.resource.data.status == 'rejected'
            && bookingOperatorUid(request.resource.data) == bookingOperatorUid(resource.data)
            && bookingOperatorUid(request.resource.data) == null
            && request.resource.data.keys().hasAny(['rejectedBy'])
            && request.resource.data.rejectedBy is list
            && request.resource.data.rejectedBy.hasAny([request.auth.uid])
            && (
              (
                !resource.data.keys().hasAny(['rejectedBy'])
                && request.resource.data.rejectedBy.size() == 1
              )
              || (
                resource.data.keys().hasAny(['rejectedBy'])
                && resource.data.rejectedBy is list
                && !resource.data.rejectedBy.hasAny([request.auth.uid])
                && request.resource.data.rejectedBy.hasAll(resource.data.rejectedBy)
                && request.resource.data.rejectedBy.size() == resource.data.rejectedBy.size() + 1
              )
            )
          )
        )
        && bookingUpdateHasExpectedFields()
        && validCorridorBookingMetadata(request.resource.data);

      allow delete: if false;
    }
  }
}